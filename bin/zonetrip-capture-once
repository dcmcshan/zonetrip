#!/usr/bin/env sh
set -eu

DURATION="${ZONETRIP_CAPTURE_SECONDS:-90}"
ENDPOINT="${ZONETRIP_PROCESSOR_ENDPOINT:-http://127.0.0.1:8090/process-audio}"
TMP_ROOT="${TMPDIR:-/tmp}"

tmp_file="$(mktemp "$TMP_ROOT/zonetrip-capture.XXXXXX.wav")"

cleanup() {
  rm -f "$tmp_file"
}
trap cleanup EXIT INT TERM

if command -v ffmpeg >/dev/null 2>&1; then
  ffmpeg \
    -hide_banner \
    -loglevel error \
    -f alsa \
    -i "${ZONETRIP_AUDIO_DEVICE:-default}" \
    -t "$DURATION" \
    -ac 1 \
    -ar 16000 \
    -y "$tmp_file"
elif command -v arecord >/dev/null 2>&1; then
  arecord \
    -q \
    -D "${ZONETRIP_AUDIO_DEVICE:-default}" \
    -f S16_LE \
    -c 1 \
    -r 16000 \
    -d "$DURATION" \
    "$tmp_file"
else
  echo "ffmpeg or arecord is required for local microphone capture" >&2
  exit 1
fi

curl -fsS \
  -X POST "$ENDPOINT" \
  -H "Content-Type: audio/wav" \
  --data-binary "@$tmp_file"
